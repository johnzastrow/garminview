# ── Database ──────────────────────────────────────────────────────────────────
# MariaDB on a remote host (production / Docker)
GARMINVIEW_DB_BACKEND=mariadb
GARMINVIEW_DB_URL=user:password@mariadb-host:3306/garminview

# SQLite (local dev only — comment out the two lines above and uncomment below)
# GARMINVIEW_DB_BACKEND=sqlite
# GARMINVIEW_DB_PATH=garminview.db

# ── Data paths ────────────────────────────────────────────────────────────────
GARMINVIEW_HEALTH_DATA_DIR=~/HealthData   # host path; mounted to /data/HealthData in Docker
GARMINVIEW_LOG_LEVEL=INFO

# ── Security ──────────────────────────────────────────────────────────────────
GARMINVIEW_SECRET_KEY=change-me-to-something-long-and-random

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to the URL where the frontend is reachable in production
GARMINVIEW_CORS_ORIGINS=["http://localhost:8080"]

# ── Docker Compose settings ───────────────────────────────────────────────────
IMAGE_TAG=latest                 # pin to a specific version, e.g. v0.2.0
HEALTH_DATA_DIR=~/HealthData    # host dir mounted read-only into backend container
GARMINDB_CONFIG_DIR=~/.GarminDb # Garmin Connect credentials dir
GARMINVIEW_PORT=8080             # host port the frontend listens on
